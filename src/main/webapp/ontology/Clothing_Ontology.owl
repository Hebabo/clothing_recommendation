    <!-- http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_GetCategoryItems -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_GetCategoryItems">
        <rdf:type rdf:resource="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#StoredQuery"/>
        <hasSPARQLText>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX clothing-ontology: &lt;http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#&gt;

SELECT DISTINCT ?targetCategory ?itemName ?price ?imagePath ?brand ?style 
WHERE { 
  ?item rdf:type ?targetCategory .
  
  ?item clothing-ontology:hasName ?itemName .
  ?item clothing-ontology:hasPrice ?price .
  ?item clothing-ontology:hasImagePath ?imagePath .
  ?item clothing-ontology:hasBrand ?brand .
  ?item clothing-ontology:hasStyle ?style .


   FILTER(?targetCategory NOT IN (owl:NamedIndividual, clothing-ontology:ClothingItem))
  
}</hasSPARQLText>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_GetCrossSelling -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_GetCrossSelling">
        <rdf:type rdf:resource="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#StoredQuery"/>
        <hasSPARQLText>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX clothing-ontology: &lt;http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#&gt;

SELECT DISTINCT ?targetItemName ?itemName ?price ?imagePath ?brand ?style
WHERE { 
  ?targetItem clothing-ontology:worksWellWith ?item .
  
  ?targetItem clothing-ontology:hasName ?targetItemName .
  ?item clothing-ontology:hasName ?itemName .
  ?item clothing-ontology:hasPrice ?price .
  ?item clothing-ontology:hasImagePath ?imagePath .
  ?item clothing-ontology:hasBrand ?brand .
  ?item clothing-ontology:hasStyle ?style .
}</hasSPARQLText>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_GetRecommendations -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_GetRecommendations">
        <rdf:type rdf:resource="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#StoredQuery"/>
        <hasSPARQLText>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX clothing-ontology: &lt;http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#&gt;

SELECT DISTINCT ?itemName ?price ?imagePath ?brand ?style
WHERE { 
  ?item clothing-ontology:isRecommendedFor ?targetUser . 
  
  ?item clothing-ontology:hasName ?itemName .
  ?item clothing-ontology:hasPrice ?price .
  ?item clothing-ontology:hasImagePath ?imagePath .
  ?item clothing-ontology:hasBrand ?brand .
  ?item clothing-ontology:hasStyle ?style .
}</hasSPARQLText>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_GetSimilarItems -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_GetSimilarItems">
        <rdf:type rdf:resource="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#StoredQuery"/>
        <hasSPARQLText>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX clothing-ontology: &lt;http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#&gt;

SELECT DISTINCT ?targetItemName ?itemName ?price ?imagePath ?brand ?style
WHERE { 
  ?targetItem clothing-ontology:isSimilarTo ?item .
  
?targetItem clothing-ontology:hasName ?targetItemName .

  ?item clothing-ontology:hasName ?itemName .
  ?item clothing-ontology:hasPrice ?price .
  ?item clothing-ontology:hasImagePath ?imagePath .
  ?item clothing-ontology:hasBrand ?brand .
  ?item clothing-ontology:hasStyle ?style .
  
}</hasSPARQLText>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_HasLiked -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#Query_HasLiked">
        <rdf:type rdf:resource="http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#StoredQuery"/>
        <hasSPARQLText>PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
PREFIX clothing-ontology: &lt;http://www.semanticweb.org/malakhussein/ontologies/2026/3/clothing-ontology#&gt;

SELECT DISTINCT ?targetUser ?itemName ?price ?imagePath ?brand ?style
WHERE { 

  ?targetUser clothing-ontology:hasLiked ?item .

  ?item clothing-ontology:hasName ?itemName .
  ?item clothing-ontology:hasPrice ?price .
  ?item clothing-ontology:hasImagePath ?imagePath .
  ?item clothing-ontology:hasBrand ?brand .
  ?item clothing-ontology:hasStyle ?style .
}</hasSPARQLText>
    </owl:NamedIndividual>
    


